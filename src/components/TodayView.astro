<section class="view-panel active" data-view="today" aria-label="Today summary">
  <article class="panel hero-card">
    <p class="eyebrow">Focus Planner</p>
    <h1 class="title">Habitly</h1>
    <p class="subtitle">Planifica y ejecuta sin friccion.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <p class="stat-label">Bloques completados</p>
        <p id="completed-hours" class="stat-value">0h</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Pendientes hoy</p>
        <p id="today-pending" class="stat-value">0</p>
      </div>
    </div>
  </article>

  <article class="panel">
    <header class="section-header">
      <h2 id="today-title">Hoy</h2>
      <span id="today-task-count" class="muted-pill">0 tareas</span>
    </header>
    <div id="today-task-list" class="task-stack"></div>
  </article>
</section>
