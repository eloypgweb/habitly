---
import AppNavigation from "../components/AppNavigation.astro";
import TodayView from "../components/TodayView.astro";
import WeekView from "../components/WeekView.astro";
import MonthView from "../components/MonthView.astro";
import GoalsView from "../components/GoalsView.astro";
import ProfileView from "../components/ProfileView.astro";
import TaskModal from "../components/TaskModal.astro";

import "../styles/app.css";

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content="#0f1522" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>Habitly - Weekly Study Planner</title>
	</head>
	<body>
		<main class="app-shell">
			<header class="app-top">
				<p class="app-date" id="app-date"></p>
				<h1 class="app-title">Habitly Planner</h1>
				<p class="sync-pill" id="sync-status" data-sync-status="idle">Sin cambios recientes</p>
			</header>

			<AppNavigation />

			<section class="views-wrap">
				<TodayView />
				<WeekView />
				<MonthView />
				<GoalsView />
				<ProfileView />
			</section>
		</main>

		<TaskModal />

		<script>
			import "../scripts/app.js";
		</script>
	</body>
</html>
