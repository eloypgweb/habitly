<section class="view-panel" data-view="month" aria-label="Month view">
  <article class="panel">
    <header class="section-header">
      <h2 id="month-title">Mes actual</h2>
      <div class="month-controls">
        <button class="mini-btn" type="button" data-action="prev-month">Prev</button>
        <button class="mini-btn" type="button" data-action="next-month">Next</button>
      </div>
    </header>
    <div class="month-weekdays" aria-hidden="true">
      <span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span>
    </div>
    <div id="month-grid" class="month-grid"></div>
  </article>
</section>
