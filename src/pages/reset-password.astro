---
import "../styles/auth.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1522" />
    <title>Habitly - Nueva contrasena</title>
  </head>
  <body class="auth-body">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-eyebrow">Habitly</p>
        <h1>Crear nueva contrasena</h1>
        <p class="auth-subtitle">Introduce tu nueva contrasena para recuperar el acceso.</p>

        <form id="reset-form" class="auth-form">
          <label>
            <span>Nueva contrasena</span>
            <div class="password-row">
              <input
                id="reset-password"
                name="password"
                type="password"
                minlength="6"
                required
                autocomplete="new-password"
              />
              <button
                type="button"
                class="toggle-password-btn"
                data-toggle-password="reset-password"
                aria-label="Mostrar u ocultar contrasena"
                aria-pressed="false"
              >
                👁
              </button>
            </div>
          </label>

          <label>
            <span>Confirmar contrasena</span>
            <div class="password-row">
              <input
                id="reset-password-confirm"
                name="password-confirm"
                type="password"
                minlength="6"
                required
                autocomplete="new-password"
              />
              <button
                type="button"
                class="toggle-password-btn"
                data-toggle-password="reset-password-confirm"
                aria-label="Mostrar u ocultar contrasena"
                aria-pressed="false"
              >
                👁
              </button>
            </div>
          </label>

          <p id="auth-feedback" class="auth-feedback" role="status" aria-live="polite"></p>
          <button id="reset-submit" type="submit" class="auth-btn">Guardar nueva contrasena</button>
        </form>

        <p class="auth-switch">
          <a href="/login">Volver a iniciar sesion</a>
        </p>
      </section>
    </main>

    <script>
      import "../scripts/auth.js";
    </script>
  </body>
</html>
