---
import "../styles/auth.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1522" />
    <title>Habitly - Iniciar sesion</title>
  </head>
  <body class="auth-body">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-eyebrow">Habitly</p>
        <h1>Inicia sesion</h1>
        <p class="auth-subtitle">Accede a tu planner y sincroniza tus datos.</p>

        <form id="login-form" class="auth-form">
          <label>
            <span>Correo o usuario</span>
            <input
              id="login-identifier"
              name="identifier"
              type="text"
              required
              autocomplete="username"
              placeholder="tu@email.com o tu_usuario"
            />
          </label>

          <label>
            <span>Contrasena</span>
            <div class="password-row">
              <input
                id="login-password"
                name="password"
                type="password"
                minlength="6"
                required
                autocomplete="current-password"
              />
              <button
                type="button"
                class="toggle-password-btn"
                data-toggle-password="login-password"
                aria-label="Mostrar u ocultar contrasena"
                aria-pressed="false"
              >
                👁
              </button>
            </div>
          </label>

          <p class="auth-inline-link">
            <a href="/forgot-password">Has olvidado tu contrasena?</a>
          </p>

          <p id="auth-feedback" class="auth-feedback" role="status" aria-live="polite"></p>
          <button id="login-submit" type="submit" class="auth-btn">Entrar</button>
        </form>

        <p class="auth-switch">
          No tienes cuenta?
          <a href="/register">Crear cuenta</a>
        </p>
      </section>
    </main>

    <script>
      import "../scripts/auth.js";
    </script>
  </body>
</html>
