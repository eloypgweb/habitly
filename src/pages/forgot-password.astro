---
import "../styles/auth.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1522" />
    <title>Habitly - Recuperar contrasena</title>
  </head>
  <body class="auth-body">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-eyebrow">Habitly</p>
        <h1>Recuperar contrasena</h1>
        <p class="auth-subtitle">Te enviaremos un enlace para crear una nueva contrasena.</p>

        <form id="forgot-form" class="auth-form">
          <label>
            <span>Email</span>
            <input
              id="forgot-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="tu@email.com"
            />
          </label>

          <p id="auth-feedback" class="auth-feedback" role="status" aria-live="polite"></p>
          <button id="forgot-submit" type="submit" class="auth-btn">Enviar enlace</button>
        </form>

        <p class="auth-switch">
          Ya te acuerdas?
          <a href="/login">Volver a iniciar sesion</a>
        </p>
      </section>
    </main>

    <script>
      import "../scripts/auth.js";
    </script>
  </body>
</html>
