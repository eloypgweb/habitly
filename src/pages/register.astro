---
import "../styles/auth.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1522" />
    <title>Habitly - Registro</title>
  </head>
  <body class="auth-body">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-eyebrow">Habitly</p>
        <h1>Crea tu cuenta</h1>
        <p class="auth-subtitle">Registrate para guardar tu progreso entre dispositivos.</p>

        <form id="register-form" class="auth-form">
          <label>
            <span>Email</span>
            <input id="register-email" name="email" type="email" required autocomplete="email" />
          </label>

          <label>
            <span>Usuario</span>
            <input
              id="register-username"
              name="username"
              type="text"
              minlength="3"
              maxlength="24"
              required
              autocomplete="username"
              placeholder="ej: eloy_23"
            />
          </label>

          <label>
            <span>Contrasena</span>
            <div class="password-row">
              <input
                id="register-password"
                name="password"
                type="password"
                minlength="6"
                required
                autocomplete="new-password"
              />
              <button
                type="button"
                class="toggle-password-btn"
                data-toggle-password="register-password"
                aria-label="Mostrar u ocultar contrasena"
                aria-pressed="false"
              >
                👁
              </button>
            </div>
          </label>

          <label>
            <span>Confirmar contrasena</span>
            <div class="password-row">
              <input
                id="register-password-confirm"
                name="password-confirm"
                type="password"
                minlength="6"
                required
                autocomplete="new-password"
              />
              <button
                type="button"
                class="toggle-password-btn"
                data-toggle-password="register-password-confirm"
                aria-label="Mostrar u ocultar contrasena"
                aria-pressed="false"
              >
                👁
              </button>
            </div>
          </label>

          <p id="auth-feedback" class="auth-feedback" role="status" aria-live="polite"></p>
          <button id="register-submit" type="submit" class="auth-btn">Crear cuenta</button>
        </form>

        <p class="auth-switch">
          Ya tienes cuenta?
          <a href="/login">Iniciar sesion</a>
        </p>
      </section>
    </main>

    <div id="register-success-modal" class="auth-modal" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="auth-modal-card success">
        <p class="auth-modal-eyebrow">Registro completado</p>
        <h2>Revisa tu bandeja de entrada</h2>
        <p>
          Te hemos enviado un correo para confirmar tu cuenta. Cuando la verifiques, ya podrás iniciar sesion.
        </p>
      </div>
    </div>

    <script>
      import "../scripts/auth.js";
    </script>
  </body>
</html>
